# Copy this file to .env for the backend. Do not commit real .env files.

# DeepSeek LLM settings. The rule-based router works without these values.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Safe LLM fallback settings. Disabled by default; tests use mocks.
LLM_FALLBACK_MODE=disabled
LLM_FALLBACK_ENABLED=false
ALLOW_LIVE_LLM=false
LLM_FALLBACK_PROVIDER=deepseek
LLM_FALLBACK_BASE_URL=https://api.deepseek.com
LLM_FALLBACK_MODEL=deepseek-chat
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_TIMEOUT_SECONDS=2.5
LLM_FALLBACK_MAX_TOKENS=180
LLM_FALLBACK_TEMPERATURE=0
LLM_FALLBACK_TOP_CANDIDATES=8
LLM_FALLBACK_MIN_CONFIDENCE=0.65
LLM_FALLBACK_SPECULATIVE_ENABLED=false
LLM_FALLBACK_REPLAY_FILE=
LLM_FALLBACK_SHADOW_SOURCE=fake

# Optional backend env file override. Leave empty to use the project-root .env.
# Prefer an absolute path if you set this.
BACKEND_ENV_FILE=

# Optional menu config override. Leave empty to use backend/app/data/menu.json.
MENU_CONFIG_PATH=

# Voice gateway master switches.
# VOICE_ENABLED=false keeps the app in text-only mode.
# VOICE_DEBUG=true prints backend voice auto-TTS diagnostics.
VOICE_ENABLED=false
VOICE_DEBUG=false

# ASR settings. VOSK_MODEL_PATH must point to an extracted Vosk model directory.
ASR_ENGINE=vosk
VOSK_MODEL_PATH=./models/asr/vosk-cn
ASR_SAMPLE_RATE=16000
ASR_LANGUAGE=zh-cn
ASR_FINAL_SILENCE_MS=800
ASR_MAX_UTTERANCE_MS=12000

# TTS settings. The current implementation uses pyttsx3 and server-side playback.
# TTS_PLAYBACK_TARGET=server means audio plays on the machine running FastAPI.
TTS_ENABLED=true
TTS_ENGINE=pyttsx3
TTS_RATE=180
TTS_VOLUME=1.0
TTS_VOICE_NAME=
TTS_PLAYBACK_TARGET=server
TTS_ENGINE_RECREATE_PER_TASK=true

# Voice TTS style settings.
# VOICE_TTS_ENABLED overrides TTS_ENABLED when explicitly set.
# VOICE_TTS_STYLE values: friendly, calm, clear, professional, cute, fast, elder_friendly.
# VOICE_TTS_PROVIDER values: auto, pyttsx3.
# VOICE_TTS_PITCH is recorded in status but not applied by pyttsx3.
VOICE_TTS_ENABLED=
VOICE_TTS_STYLE=friendly
VOICE_TTS_PROVIDER=auto
VOICE_TTS_PITCH=
VOICE_TTS_LANG=zh-CN

# Reserved provider paths read by config but not required for the default demo.
PIPER_BIN=
PIPER_MODEL_PATH=
PIPER_CONFIG_PATH=
WHISPER_CPP_BIN=
WHISPER_MODEL_PATH=

# Frontend Vite settings. Put these in frontend/.env.local or export them before npm run dev.
# Leave VITE_API_BASE_URL unset to use http://localhost:8000/api.
# Set VITE_API_BASE_URL=/api to use the local Vite dev proxy.
VITE_API_BASE_URL=
VITE_BACKEND_PROXY_TARGET=http://localhost:8000
VITE_DEBUG_VOICE=false
